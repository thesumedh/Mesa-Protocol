{
  "name": "@mesaprotocol/runtime",
  "version": "0.3.1",
  "description": "Mesa durable financial workflow runtime",
  "main": "dist/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thesumedh/Mesa-Protocol.git"
  },
  "homepage": "https://github.com/thesumedh/Mesa-Protocol#readme",
  "keywords": [
    "stellar",
    "soroban",
    "workflow",
    "orchestration"
  ],
  "files": [
    "dist",
    "Dockerfile",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --shims && node -e \"const fs = require('fs'); fs.mkdirSync('dist/store', { recursive: true }); fs.copyFileSync('src/store/schema.sql', 'dist/store/schema.sql'); fs.mkdirSync('dist/server', { recursive: true }); fs.copyFileSync('src/server/dashboard.html', 'dist/server/dashboard.html');\"",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "ts-node src/test/foundation.test.ts && ts-node src/test/edge-cases.test.ts",
    "test:edge": "ts-node src/test/edge-cases.test.ts",
    "test:anchor": "ts-node src/test/anchor.test.ts",
    "test:dashboard": "ts-node src/test/dashboard.test.ts",
    "test:stellar": "ts-node src/test/stellar.test.ts",
    "test:payroll": "ts-node src/test/payroll.test.ts",
    "demo:stellar": "ts-node src/demo/stellar.demo.ts",
    "demo:payroll": "ts-node src/demo/payroll.demo.ts"
  },
  "dependencies": {
    "@mesaprotocol/schema": "^0.3.0",
    "@stellar/stellar-sdk": "^12.3.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
