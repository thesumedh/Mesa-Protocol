{
  "name": "@mesaprotocol/sdk",
  "version": "0.3.1",
  "description": "Lightweight Mesa financial workflow SDK for Stellar",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thesumedh/Mesa-Protocol.git"
  },
  "homepage": "https://github.com/thesumedh/Mesa-Protocol#readme",
  "keywords": [
    "stellar",
    "soroban",
    "workflow",
    "orchestration"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "ts-node src/flow.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mesaprotocol/schema": "^0.3.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@stellar/freighter-api": "^3.0.0",
    "@types/node": "^20.11.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@stellar/freighter-api": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@stellar/freighter-api": {
      "optional": true
    }
  }
}
