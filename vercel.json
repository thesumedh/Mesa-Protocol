{
  "buildCommand": "cd mesa-protocol/frontend && yarn build",
  "devCommand": "cd mesa-protocol/frontend && yarn dev",
  "installCommand": "cd mesa-protocol/frontend && yarn install --frozen-lockfile",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
